# ── Secrets ───────────────────────────────────────────────────────────────────
# Square API keys — never commit
.env

# ── Generated data (too large / sensitive for git) ───────────────────────────
# CSV files built by generate_common_file_from_data.py
ProcessedData/
# Raw Square exports and roster spreadsheets
RawData/
# final_file.json — generated training dataset
Training/
# Graph images produced during dataset validation
TrainingImages/

# ── Training artefacts ────────────────────────────────────────────────────────
# SFTTrainer checkpoints (can be GBs)
outputs/
# Eval checkpoints
results/
# Locally saved LoRA adapters (push to HF Hub instead)
*_4bit/
*_adapter/
# Raw model weights — always too large for git
*.safetensors

# ── Inference scratch files ───────────────────────────────────────────────────
# Generated by Inference_Notebook — not source code
all_outputs.json
all_times.json
# Scratch visualisation output
test.png

# ── Misc / dev noise ─────────────────────────────────────────────────────────
# Contains sensitive column name mappings
mask.py
# Scratchpad — not part of the project
junk.py
# Empty scratch log
json_log.csv

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# ── OS / IDE ──────────────────────────────────────────────────────────────────
.DS_Store
.vscode/
.idea/
